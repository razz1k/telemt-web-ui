# === Bundled profile (docker-compose.yml) ===
WEB_UI_PASSWORD=
TELEMT_API_AUTH=

# Host UID/GID for dev/check image build and runtime (api, telemt bind mounts). Set to match `id -u` / `id -g`.
# UID=1000
# GID=1000

# === External profile (docker-compose.external.yml) ===
TELEMT_API_URL=http://host.docker.internal:9091
TELEMT_METRICS_URL=http://host.docker.internal:9092

# Path to telemt.toml inside the api container (optional for external mode)
# Leave empty to disable config editing in Settings page
TELEMT_CONFIG_PATH=

# Host path to mount for config editing (external mode only)
# Example: TELEMT_CONFIG_HOST_PATH=./config/config.toml
TELEMT_CONFIG_HOST_PATH=

# BFF listen port (internal)
API_PORT=3000

# SQLite path inside the api container (host dir: ./data)
UI_DB_PATH=/var/lib/telemt-web-ui/state.db
