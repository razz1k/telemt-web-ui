FROM node:22-bookworm-slim

ARG UID=1000
ARG GID=1000

# better-sqlite3 native build during npm install in apps/api
RUN apt-get update \
  && apt-get install -y --no-install-recommends python3 make g++ \
  && rm -rf /var/lib/apt/lists/*

# Match host UID/GID (docker compose build.args); -o allows reuse if already taken
RUN usermod -o -u "${UID}" node \
  && groupmod -o -g "${GID}" node \
  && mkdir -p /workspace \
  && chown -R node:node /workspace

WORKDIR /workspace

USER node
